generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== UŽIVATELÉ ====================

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  passwordHash      String
  firstName         String
  lastName          String
  dateOfBirth       DateTime
  dateOfBirthChanged Boolean @default(false)
  addressStreet     String
  addressCity       String
  addressZip        String
  isPermanentResident Boolean @default(false)
  phone             String
  emailVerified     Boolean  @default(false)
  emailVerifyToken  String?

  registrationStatus String  @default("NEW") // NEW, PENDING_REVIEW, INVITED_FOR_INTERVIEW, APPROVED, REJECTED, BLOCKED
  approvedById       String?
  approvedBy         User?    @relation("ApprovedByUser", fields: [approvedById], references: [id])
  approvedUsers      User[]   @relation("ApprovedByUser")
  approvalDate       DateTime?
  approvalNote       String?
  rejectionReason    String?

  trustLevel         String   @default("NEW_MEMBER") // NEW_MEMBER, ACTIVE_BENEFICIAL, UNPROBLEMATIC, CONFLICTING, COMMENT_RESTRICTED
  internalNote       String?

  memberSince        DateTime?
  minVotingDays      Int      @default(30)

  role               String   @default("USER") // USER, REGISTRATION_MANAGER, PROJECT_REVIEWER, CONTENT_EDITOR, COMMENT_MODERATOR, ADMIN

  twoFactorEnabled   Boolean  @default(false)
  twoFactorSecret    String?
  lastLoginAt        DateTime?
  lastLoginIp        String?
  failedLoginAttempts Int     @default(0)
  lockedUntil        DateTime?
  passwordResetToken   String?
  passwordResetExpires DateTime?

  gdprConsent        Boolean  @default(false)
  gdprConsentDate    DateTime?
  rulesConsent       Boolean  @default(false)
  rulesConsentDate   DateTime?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  interviews         Interview[]
  projects           Project[]
  votes              Vote[]
  comments           Comment[]
  auditLogsUser      AuditLog[]     @relation("AuditLogUser")
  auditLogsAdmin     AuditLog[]     @relation("AuditLogAdmin")
  projectReviews     ProjectReview[]
  notifications      Notification[]
}

// ==================== OSOBNÍ POHOVORY ====================

model Interview {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  scheduledDate   DateTime
  attended        Boolean  @default(false)
  evaluation      String?
  result          String   @default("PENDING") // PENDING, RECOMMENDED, NOT_RECOMMENDED, POSTPONED
  interviewerName String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==================== PROJEKTY ====================

model Project {
  id                  String   @id @default(uuid())
  authorId            String
  author              User     @relation(fields: [authorId], references: [id])

  title               String
  summary             String
  description         String
  benefitForCity      String
  targetGroup         String
  location            String
  estimatedBudget     Float
  requestedSupport    Float
  realizationDate     String
  implementedBy       String
  isLongTerm          Boolean  @default(false)
  declaration         Boolean  @default(false)

  operatingCosts      String?
  maintainedBy        String?
  mainRisks           String?
  previouslyDiscussed String?
  publicInterest      Boolean  @default(true)
  estimatedBeneficiaries Int?
  category            String   @default("OTHER") // YOUTH, SPORT, CULTURE, PUBLIC_SPACE, EDUCATION, HISTORY_TRADITIONS, SOCIAL_HELP, SMALL_INVESTMENT, LARGE_INVESTMENT, OTHER
  budgetSize          String   @default("MEDIUM") // SMALL, MEDIUM, LARGE

  status              String   @default("SUBMITTED") // SUBMITTED, FORMAL_REVIEW, WAITING_FOR_COMPLETION, REJECTED_UNSUITABLE, SENT_FOR_INTERVIEW, APPROVED_FOR_PUBLICATION, PUBLISHED_FOR_VOTING, VOTING_ENDED, RECOMMENDED_FOR_REALIZATION, POSTPONED, REJECTED, IN_REALIZATION, COMPLETED, ARCHIVED

  adminNote           String?

  votingStartDate     DateTime?
  votingEndDate       DateTime?
  votesFor            Int      @default(0)
  votesAgainst        Int      @default(0)

  foundationComment   String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  attachments         Attachment[]
  votes               Vote[]
  comments            Comment[]
  reviews             ProjectReview[]
  statusHistory       ProjectStatusHistory[]
}

// ==================== PŘÍLOHY ====================

model Attachment {
  id           String   @id @default(uuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String
  createdAt    DateTime @default(now())
}

// ==================== HLASOVÁNÍ ====================

model Vote {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  value     String   // YES, NO
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, projectId])
}

// ==================== KOMENTÁŘE ====================

model Comment {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id])
  content      String
  isHidden     Boolean  @default(false)
  hiddenById   String?
  hiddenReason String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ==================== RECENZE PROJEKTŮ ====================

model ProjectReview {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  reviewerId  String
  reviewer    User     @relation(fields: [reviewerId], references: [id])

  statuteCompliance     Int?
  publicBenefit         Int?
  feasibility           Int?
  budgetAdequacy        Int?
  sustainability        Int?
  technicalFeasibility  Int?
  noPersonalGain        Boolean @default(true)
  conflictRisk          Int?

  overallRecommendation String // APPROVE, REJECT, NEEDS_MORE_INFO, POSTPONE
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ==================== HISTORIE STAVŮ PROJEKTU ====================

model ProjectStatusHistory {
  id         String   @id @default(uuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id])
  fromStatus String?
  toStatus   String
  changedBy  String?
  note       String?
  createdAt  DateTime @default(now())
}

// ==================== AUDIT LOG ====================

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation("AuditLogUser", fields: [userId], references: [id])
  adminId   String?
  admin     User?    @relation("AuditLogAdmin", fields: [adminId], references: [id])
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}

// ==================== NOTIFIKACE ====================

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

// ==================== CMS OBSAH ====================

model Page {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  content     String
  isPublished Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Document {
  id           String   @id @default(uuid())
  title        String
  description  String?
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String
  category     String   @default("OTHER") // STATUTES, ANNUAL_REPORT, FINANCIAL_STATEMENT, GDPR, RULES, OTHER
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model NewsArticle {
  id          String    @id @default(uuid())
  title       String
  content     String
  excerpt     String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
